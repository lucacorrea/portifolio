# Copie para .env no servidor ou configure essas variáveis no painel da hospedagem/VPS.
# Gere uma chave longa e aleatória. Exemplo:
# openssl rand -hex 32

NODE_ENV=production
PORT=8080
HOST=0.0.0.0
BRIDGE_API_KEY=troque-por-uma-chave-forte-com-64-caracteres
LOG_LEVEL=info
BAILEYS_AUTH_DIR=./auth_info_baileys
PRINT_QR_IN_TERMINAL=false
