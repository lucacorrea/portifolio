APP_NAME="FluxPay"
APP_URL="https://seudominio.com.br"
APP_BASE_PATH=
APP_ENV=development
APP_DEBUG=true

DB_HOST=localhost
DB_NAME=fluxpay_saas
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

SESSION_NAME=fluxpay_session
SESSION_SAVE_PATH=storage/sessions
SESSION_COOKIE_PATH=/

CHECKOUT_DEFAULT_PLAN_NAME=Growth
CHECKOUT_TRIAL_DAYS=7

WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_API_AUTH_HEADER=apikey
WHATSAPP_API_TIMEOUT=15
WHATSAPP_PROVIDER=bridge
WHATSAPP_BRIDGE_URL=http://127.0.0.1:8080
WHATSAPP_BRIDGE_TOKEN=
WHATSAPP_BRIDGE_AUTH_HEADER=Authorization
WHATSAPP_BRIDGE_TIMEOUT=25
WHATSAPP_INSTANCE_PREFIX=fluxpay
WHATSAPP_INTEGRATION=WHATSAPP-BAILEYS
WHATSAPP_SEND_DELAY_MS=1200
WHATSAPP_CRON_TOKEN=
