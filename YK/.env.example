APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=America/Manaus

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nome_do_banco
DB_USERNAME=usuario_do_banco
DB_PASSWORD=altere_aqui
DB_CHARSET=utf8mb4
DB_AUTO_MIGRATE=false
DB_WEB_MIGRATIONS=false

# A integracao fiscal nasce desativada e em homologacao. Gere a chave fora do
# public_html com: php -r "echo base64_encode(random_bytes(32)), PHP_EOL;"
FISCAL_INTEGRATION_ENABLED=false
FISCAL_PRODUCTION_ENABLED=false
FISCAL_MASTER_KEY=

SESSION_NAME=YKSESSID
SESSION_TIMEOUT=1800
SESSION_ABSOLUTE_TIMEOUT=28800
SESSION_REGENERATE_INTERVAL=900
SESSION_COOKIE_PATH=/YK

LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
