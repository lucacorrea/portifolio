.env
bridge/node_modules/
bridge/storage/sessions/*
bridge/storage/cache/*
bridge/storage/tmp/*
bridge/storage/locks/*
bridge/logs/*
storage/logs/*
storage/cache/*
storage/locks/*
storage/exports/*
!bridge/storage/sessions/.gitkeep
!bridge/storage/cache/.gitkeep
!bridge/storage/tmp/.gitkeep
!bridge/storage/locks/.gitkeep
!bridge/logs/.gitkeep
!storage/logs/.gitkeep
!storage/cache/.gitkeep
!storage/locks/.gitkeep
!storage/exports/.gitkeep
