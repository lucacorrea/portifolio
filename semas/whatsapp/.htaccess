Options -Indexes

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<FilesMatch "^(\.env|package\.json|package-lock\.json|README\.md|INSTALACAO\.md)$">
  Require all denied
</FilesMatch>

RedirectMatch 403 ^/semas/whatsapp/(app|config|database|storage|cron|bridge)(/|$)
