APP_NAME="SIGAS Coari"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://exemplo.gov.br/sigas
APP_TIMEZONE=America/Manaus

DB_HOST=localhost
DB_PORT=3306
DB_NAME=nome_banco
DB_USER=usuario_banco
DB_PASSWORD=senha_segura
DB_CHARSET=utf8mb4

SESSION_NAME=SIGAS_SESSION
SESSION_LIFETIME=7200
SESSION_IDLE_TIMEOUT=1800
SESSION_COOKIE_PATH=/sigas
TRUST_PROXY_HEADERS=false
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

PRIVATE_BASE_PATH=/home/USUARIO/configuracao/sigas
SIGAS_IMAGE_PATH=/home/USUARIO/configuracao/sigas/uplouds/img
SIGAS_DOCUMENT_PATH=/home/USUARIO/configuracao/sigas/uplouds/document
SIGAS_LOG_PATH=/home/USUARIO/configuracao/sigas/logs

MAX_IMAGE_SIZE=5242880
MAX_DOCUMENT_SIZE=10485760

INSTALLATION_ENABLED=false
INSTALLATION_KEY=troque-por-uma-chave-longa-e-aleatoria
INSTALLATION_LOCK_PATH=/home/USUARIO/configuracao/sigas/installation.lock
