APP_NAME="L&J Caixa"
APP_ENV=production
APP_DEBUG=false
BASE_URL=https://seudominio.com.br/gestao
APP_URL=https://seudominio.com.br/gestao

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=lj_caixa
DB_USERNAME=usuario_do_banco
DB_PASSWORD="senha_do_banco"
DB_CHARSET=utf8mb4

SESSION_NAME=LJ_CAIXA_SESSION
SESSION_SECURE=true
SESSION_LIFETIME=7200

PRODUCT_LOOKUP_PROVIDERS=open_food_facts
PRODUCT_LOOKUP_TIMEOUT=10
PRODUCT_LOOKUP_SESSION_LIMIT=0
PRODUCT_LOOKUP_WINDOW_SECONDS=300

# Configure no .env real com a URL oficial confirmada e um contato real do responsavel.
OPENFOODFACTS_BASE_URL=
OPENFOODFACTS_USER_AGENT=

OPENPRODUCTSFACTS_BASE_URL=
OPENPRODUCTSFACTS_USER_AGENT=

COSMOS_API_BASE_URL=
COSMOS_API_TOKEN=
