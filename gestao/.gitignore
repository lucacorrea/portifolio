# =========================
# L&J Caixa - Git Ignore
# =========================

# Arquivos sensíveis
.env
.env.*
!.env.example

# Banco de dados / dumps
*.sql
*.sqlite
*.sqlite3
*.db
database/backups/
database/dumps/

# Logs
*.log
storage/logs/*
!storage/logs/.gitkeep

# Cache / temporários
storage/cache/*
storage/temp/*
!storage/cache/.gitkeep
!storage/temp/.gitkeep

# Uploads do sistema
uploads/*
!uploads/.gitkeep
!uploads/produtos/
!uploads/empresas/
!uploads/comprovantes/
uploads/produtos/*
uploads/empresas/*
uploads/comprovantes/*
!uploads/produtos/.gitkeep
!uploads/empresas/.gitkeep
!uploads/comprovantes/.gitkeep

# Dependências Node/Capacitor
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build Android/iOS
android/
ios/
dist/
build/
www/build/

# IDEs / editores
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Sistema operacional
.DS_Store
Thumbs.db
desktop.ini

# Arquivos compactados
*.zip
*.rar
*.7z
*.tar
*.gz

# Certificados / chaves
*.pem
*.key
*.crt
*.p12
*.keystore
*.jks

# Composer, caso use futuramente
vendor/
composer.lock

# PHPUnit / testes
.phpunit.result.cache
coverage/

# Arquivos de backup
*.bak
*.backup
*.old
*.tmp